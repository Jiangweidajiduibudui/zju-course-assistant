# 同源 Fastify API（开发期 vite 通过 /api 代理到这里）
PORT=3000
HOST=127.0.0.1

# PostgreSQL —— 仅存 chalaoshi 公共缓存与抓取 lease，不持久化任何用户规划数据（D33、D42）
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zju_course_assistant

# chalaoshi 域名可配置（docs/03 §3：.de 可能被墙，不可达是常态场景，必须可降级）
CHALAOSHI_BASE_URL=https://chalaoshi.de
CHALAOSHI_API_BASE_URL=https://api.chalaoshi.de

# 注意：这里永远不会出现 LLM key —— key 由用户在前端配置，只随单次请求进入后端内存（D40）。
